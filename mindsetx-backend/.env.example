# MindsetX Backend Environment Variables
# Copy this to .env and fill in your values

# App
APP_ENV=development

# JWT — Generate two DIFFERENT secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string-for-access-tokens
REFRESH_SECRET_KEY=change-this-to-a-different-random-64-char-hex-string-for-refresh

# JWT Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/mindsetx

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
AUTH_RATE_LIMIT=5/minute
